{
  "name": "opencode-office-add-in",
  "version": "1.0.0",
  "description": "OpenCode Office add-in for Word, Excel, PowerPoint, and OneNote.",
  "main": "src/tray/main.js",
  "scripts": {
    "dev": "node src/server.js",
    "start": "node src/server-prod.js",
    "start:tray": "bun install --silent && bun run build && electron .",
    "build": "bun run generate:office-tools && vite build",
    "build:icons": "node scripts/generate-icons.js",
    "generate:office-tools": "node scripts/generate-office-tools.js",
    "build:installer": "bun run clean:extraneous && bun run build && electron-builder",
    "build:installer:win": "bun run clean:extraneous && bun run build && electron-builder --win",
    "build:installer:mac": "bun run clean:extraneous && bun run build && electron-builder --mac",
    "clean:extraneous": "node scripts/clean-extraneous.js",
    "package:tray": "node scripts/package-tray.js",
    "test": "bun run generate:office-tools && vitest run"
  },
  "pkg": {
    "assets": [],
    "scripts": [],
    "outputPath": "build"
  },
  "build": {
    "appId": "com.opencode.office-addin",
    "productName": "OpenCode Office Add-in",
    "publish": null,
    "directories": {
      "output": "build/electron"
    },
    "asarUnpack": [],
    "files": [
      ".opencode/**/*",
      "src/tray/**/*",
      "src/server-prod.js",
      "node_modules/**/*",
      "!node_modules/office-addin-*/**",
      "!node_modules/npm-*/**",
      "!node_modules/read-package-json-fast/**"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "dist"
      },
      {
        "from": "certs",
        "to": "certs"
      },
      {
        "from": "assets",
        "to": "assets"
      },
      {
        "from": "manifest.xml",
        "to": "manifest.xml"
      },
      {
        "from": ".opencode",
        "to": ".opencode"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/tray-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/tray-icon.ico",
      "uninstallerIcon": "assets/tray-icon.ico",
      "include": "installer/windows/nsis-scripts.nsh"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "installer/macos/icon.icns",
      "category": "public.app-category.productivity",
      "extendInfo": {
        "LSUIElement": true
      }
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "bun@1.3.11",
  "type": "commonjs",
  "devDependencies": {
    "@types/office-js": "^1.0.585",
    "@types/office-runtime": "^1.0.36",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^6.0.1",
    "@yao-pkg/pkg": "^6.14.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "html-webpack-plugin": "^5.6.6",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5",
    "ts-loader": "^9.5.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-html": "^3.2.2",
    "vitest": "^4.1.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.73.5",
    "@fluentui/react-icons": "^2.0.323",
    "@opencode-ai/sdk": "^1.3.6",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fflate": "^0.8.2",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "turndown": "^7.2.2",
    "vscode-jsonrpc": "^8.2.1",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  }
}
