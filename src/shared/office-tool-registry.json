  "set_document_content": {
    "hosts": ["word"],
    "description": "Replace the current Word document with new HTML content.",
    "mutating": true,
    "parameters": {
      "type": "object",
      "properties": {
        "html": { "type": "string", "description": "Full HTML to replace the document body." }
      },
      "required": ["html"]
    },
    "ui": { "icon": "✏️", "activity": { "type": "static", "text": "Updating document" } }
  },
  "set_document_part": {
    "hosts": ["word"],
    "description": "Update a specific Word document part using an address.",
    "mutating": true,
    "parameters": {
      "type": "object",
      "properties": {
        "address": { "type": "string", "description": "Document part address such as section[1].header.primary, section[*], or table_of_contents." },
        "operation": { "type": "string", "enum": ["replace", "append", "clear", "insert", "configure"], "description": "Operation to perform." },
        "html": { "type": "string", "description": "HTML content to write when updating a body-like part." },
        "differentFirstPage": { "type": "boolean", "description": "Use different first-page headers and footers for a section target." },
        "oddAndEvenPages": { "type": "boolean", "description": "Use different odd and even page headers and footers for a section target." },
        "headerDistance": { "type": "number", "description": "Header distance in points for a section target." },
        "footerDistance": { "type": "number", "description": "Footer distance in points for a section target." },
        "location": { "type": "string", "enum": ["replace", "before", "after", "start", "end"], "description": "Placement for TOC insertion." },
        "upperHeadingLevel": { "type": "number", "description": "Starting heading level for TOC insertion." },
        "lowerHeadingLevel": { "type": "number", "description": "Ending heading level for TOC insertion." },
        "includePageNumbers": { "type": "boolean", "description": "Include page numbers in TOC insertion." },
        "rightAlignPageNumbers": { "type": "boolean", "description": "Right-align page numbers in TOC insertion." },
        "useHyperlinksOnWeb": { "type": "boolean", "description": "Use hyperlinks for TOC entries on web publishing." }
      },
      "required": ["address"]
    },
    "ui": { "icon": "🧩", "activity": { "type": "address", "prefix": "Updating " } }
  },
