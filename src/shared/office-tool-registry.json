  "get_workbook_content": {
    "hosts": ["excel"],
    "description": "Read values and formulas from an Excel worksheet or range, with optional rich cell metadata.",
    "mutating": false,
    "parameters": {
      "type": "object",
      "properties": {
        "sheetName": { "type": "string", "description": "Worksheet name to read. Defaults to the active sheet." },
        "range": { "type": "string", "description": "Optional cell range such as A1:D10." },
        "detail": { "type": "boolean", "description": "Include display text, number formats, validation, merged areas, and table or PivotTable overlap details." }
      }
    },
    "ui": { "icon": "📄", "activity": { "type": "sheet_name_or_default", "field": "sheetName", "prefix": "Reading ", "default": "Reading worksheet" } }
  },
  "set_workbook_content": {
    "hosts": ["excel"],
    "description": "Write tabular data to an Excel worksheet range.",
    "mutating": true,
    "parameters": {
      "type": "object",
      "properties": {
        "sheetName": { "type": "string", "description": "Worksheet name to write. Defaults to the active sheet." },
        "startCell": { "type": "string", "description": "Starting cell such as A1." },
        "data": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "anyOf": [{ "type": "string" }, { "type": "number" }, { "type": "boolean" }] }
          },
          "description": "Two-dimensional array of cell values."
        },
        "useFormulas": { "type": "boolean", "description": "Treat strings starting with = as formulas." },
        "clearMode": { "type": "string", "enum": ["none", "contents", "all"], "description": "Optionally clear the destination before writing." },
        "createTable": { "type": "boolean", "description": "Create an Excel table over the written range after writing." },
        "tableName": { "type": "string", "description": "Optional table name when createTable is true." },
        "hasHeaders": { "type": "boolean", "description": "Whether the written range includes a header row when createTable is true." },
        "tableStyle": { "type": "string", "description": "Optional Excel table style when createTable is true." }
      },
      "required": ["startCell", "data"]
    },
    "ui": { "icon": "✏️", "activity": { "type": "sheet_name_or_default", "field": "sheetName", "prefix": "Updating ", "default": "Updating worksheet" } }
  },
  "get_selected_range": {
