#!/bin/bash

set -e

LAUNCHAGENT_ID="com.opencode.office-addin"
APP_NAME="OpenCode Office Add-in"

resolve_install_user() {
    if [ -n "${USER:-}" ] && [ "${USER}" != "root" ]; then
        printf '%s\n' "$USER"
        return
    fi

    if [ -n "${SUDO_USER:-}" ]; then
        printf '%s\n' "$SUDO_USER"
        return
    fi

    stat -f "%Su" /dev/console
}

resolve_user_home() {
    dscl . -read "/Users/$1" NFSHomeDirectory | awk '{print $2}'
}

run_cleanup_action() {
    local install_user="$1"
    local action_name="$2"
    local action_value="$3"

    case "$action_name" in
        unload-launch-agent)
            if [ -f "$action_value" ]; then
                echo "Stopping any existing login helper..."
                sudo -u "$install_user" launchctl unload "$action_value" 2>/dev/null || true
            fi
            ;;
        kill-process)
            pkill -f "$action_value" 2>/dev/null || true
            ;;
    esac
}

main() {
    local install_user
    local user_home
    local launch_agent_path

    install_user="$(resolve_install_user)"
    user_home="$(resolve_user_home "$install_user")"
    launch_agent_path="${user_home}/Library/LaunchAgents/${LAUNCHAGENT_ID}.plist"

    run_cleanup_action "$install_user" unload-launch-agent "$launch_agent_path"
    run_cleanup_action "$install_user" kill-process "$APP_NAME"
    run_cleanup_action "$install_user" kill-process "copilot-office-server"
    run_cleanup_action "$install_user" kill-process "opencode-office-server"

    echo "Installer preflight cleanup complete"
}

main "$@"
exit 0
