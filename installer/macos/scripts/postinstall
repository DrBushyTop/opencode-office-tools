#!/bin/bash

set -e

APP_DIR="/Applications/OpenCode Office Add-in.app"
RESOURCES_DIR="${APP_DIR}/Contents/Resources"
MANIFEST_PATH="${RESOURCES_DIR}/manifest.xml"
MANIFEST_FILENAME="manifest.xml"
LAUNCHAGENT_ID="com.opencode.office-addin"
CERT_CONFIG_PATH="${RESOURCES_DIR}/certs/localhost.conf"

manifest_id() {
    local manifest_path="$1"

    if [ ! -f "$manifest_path" ]; then
        return 1
    fi

    if command -v xmllint >/dev/null 2>&1; then
        xmllint --xpath 'string(/*[local-name()="OfficeApp"]/*[local-name()="Id"][1])' "$manifest_path" 2>/dev/null
        return 0
    fi

    grep -o '<Id>[^<]*</Id>' "$manifest_path" | sed -E 's#</?Id>##g' | head -n 1
}

is_opencode_manifest_name() {
    local filename="$1"
    [ "$filename" = "manifest.xml" ] || [ "$filename" = "opencode-office-addin.xml" ]
}

remove_matching_manifests() {
    local wef_dir="$1"
    local target_manifest_id="$2"

    [ -d "$wef_dir" ] || return 0

    for existing_manifest in "$wef_dir"/*.xml; do
        [ -e "$existing_manifest" ] || continue

        local existing_id
        existing_id="$(manifest_id "$existing_manifest")"
        if [ -n "$target_manifest_id" ] && [ "$existing_id" = "$target_manifest_id" ]; then
            rm -f "$existing_manifest"
            continue
        fi

        if [ -z "$target_manifest_id" ] && is_opencode_manifest_name "$(basename "$existing_manifest")"; then
            rm -f "$existing_manifest"
        fi
    done
}

resolve_install_user() {
    if [ -n "${USER:-}" ] && [ "${USER}" != "root" ]; then
        printf '%s\n' "$USER"
        return
    fi

    if [ -n "${SUDO_USER:-}" ]; then
        printf '%s\n' "$SUDO_USER"
        return
    fi

    stat -f "%Su" /dev/console
}

resolve_user_home() {
    dscl . -read "/Users/$1" NFSHomeDirectory | awk '{print $2}'
}

user_data_dir() {
    printf '%s/Library/Application Support/OpenCode Office Add-in\n' "$1"
}

certificate_dir() {
    printf '%s/certs\n' "$1"
}

install_launch_agent() {
    local install_user="$1"
    local user_home="$2"
    local target_file="${user_home}/Library/LaunchAgents/${LAUNCHAGENT_ID}.plist"

    mkdir -p "${user_home}/Library/LaunchAgents"
    cat > "$target_file" <<'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.opencode.office-addin</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/open</string>
        <string>-a</string>
        <string>/Applications/OpenCode Office Add-in.app</string>
        <string>--args</string>
        <string>--hidden</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <false/>
    <key>StandardOutPath</key>
    <string>/tmp/opencode-office-addin.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/opencode-office-addin.err</string>
</dict>
</plist>
EOF

    chown "$install_user":staff "$target_file"
    chmod 644 "$target_file"
    printf '%s\n' "$target_file"
}

sync_manifest_registrations() {
    local install_user="$1"
    local user_home="$2"

    if [ ! -f "$MANIFEST_PATH" ]; then
        echo "Note: No manifest found at $MANIFEST_PATH"
        return
    fi

    local target_manifest_id
    target_manifest_id="$(manifest_id "$MANIFEST_PATH")"
    local host_dirs=(
        "$user_home/Library/Containers/com.microsoft.Word/Data/Documents/wef"
        "$user_home/Library/Containers/com.microsoft.Powerpoint/Data/Documents/wef"
        "$user_home/Library/Containers/com.microsoft.Excel/Data/Documents/wef"
        "$user_home/Library/Containers/com.microsoft.onenote.mac/Data/Documents/wef"
    )

    local wef_dir
    for wef_dir in "${host_dirs[@]}"; do
        mkdir -p "$wef_dir"
        remove_matching_manifests "$wef_dir" "$target_manifest_id"
        cp "$MANIFEST_PATH" "$wef_dir/$MANIFEST_FILENAME"
        chown -R "$install_user":staff "$wef_dir"
    done

    echo "Office sideload registration refreshed for Word, PowerPoint, Excel, and OneNote"
}

ensure_local_certificate() {
    local install_user="$1"
    local user_home="$2"
    local data_dir
    local cert_dir
    local cert_path
    local key_path
    local thumbprint_path

    data_dir="$(user_data_dir "$user_home")"
    cert_dir="$(certificate_dir "$data_dir")"
    cert_path="$cert_dir/localhost.pem"
    key_path="$cert_dir/localhost-key.pem"
    thumbprint_path="$cert_dir/thumbprint.txt"

    mkdir -p "$cert_dir"
    chown -R "$install_user":staff "$data_dir"

    if [ ! -f "$cert_path" ] || [ ! -f "$key_path" ]; then
        if [ ! -f "$CERT_CONFIG_PATH" ]; then
            echo "Error: Missing certificate config at $CERT_CONFIG_PATH"
            exit 1
        fi

        sudo -u "$install_user" openssl req -x509 -nodes -newkey rsa:2048 \
            -keyout "$key_path" \
            -out "$cert_path" \
            -days 1825 \
            -config "$CERT_CONFIG_PATH" \
            -extensions v3_req >/dev/null 2>&1
        chown "$install_user":staff "$cert_path" "$key_path"
        chmod 600 "$key_path"
        chmod 644 "$cert_path"
    fi

    openssl x509 -in "$cert_path" -fingerprint -sha1 -noout | cut -d= -f2 | tr -d ':' > "$thumbprint_path"
    chown "$install_user":staff "$thumbprint_path"
    chmod 644 "$thumbprint_path"

    printf '%s\n' "$cert_path"
}

trust_certificate() {
    local cert_path="$1"

    echo "Trusting localhost HTTPS certificate..."
    if security add-trusted-cert -d -r trustRoot -k /Library/Keychains/System.keychain "$cert_path" 2>&1; then
        echo "Local certificate trust installed"
    else
        echo "Warning: Could not add the certificate to the system keychain."
        echo "You may need to trust it manually:"
        echo "  1. Open Keychain Access"
        echo "  2. Drag $cert_path to the System keychain"
        echo "  3. Double-click the localhost cert and set 'Always Trust'"
    fi
}

start_runtime_session() {
    local install_user="$1"
    local launch_agent_path="$2"

    sudo -u "$install_user" launchctl unload "$launch_agent_path" 2>/dev/null || true
    sudo -u "$install_user" launchctl load "$launch_agent_path"
    sudo -u "$install_user" open -a "$APP_DIR" --args --hidden 2>/dev/null || true
}

main() {
    local install_user
    local user_home
    local launch_agent_path
    local cert_path

    install_user="$(resolve_install_user)"
    user_home="$(resolve_user_home "$install_user")"

    echo "Installing for login user: $install_user"
    echo "Resolved home directory: $user_home"

    launch_agent_path="$(install_launch_agent "$install_user" "$user_home")"
    cert_path="$(ensure_local_certificate "$install_user" "$user_home")"
    echo "LaunchAgent installed"
    sync_manifest_registrations "$install_user" "$user_home"
    trust_certificate "$cert_path"
    start_runtime_session "$install_user" "$launch_agent_path"

    echo "Runtime launch requested"
    echo "Installation complete"
}

main "$@"
exit 0
